# Copy this file to .streamlit/secrets.toml for local runs,
# OR paste these values into Streamlit Community Cloud:
#   App -> Settings -> Secrets
#
# Do NOT commit the real secrets.toml (it is git-ignored).

# Free key from https://console.groq.com (used for chat answers).
# Embeddings run locally, so no Google/OpenAI key is needed.
GROQ_API_KEY = "your-groq-api-key-here"
